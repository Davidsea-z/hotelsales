{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-02-26",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // D1数据库配置 - 生产环境
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "microconnect-contacts-prod",
      "database_id": "fcdbbaa8-7a65-4de5-80c6-6462fd5f7989"
    }
  ]
}